---
import Avatar from "@/components/Avatar.astro";
import { getAllMembers } from "@/data/member";
import PageLayout from "@/layouts/Base.astro";
import { withBase } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const members = await getAllMembers();
const siteUrl = (path: string) => new URL(path, Astro.site).toString();
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: siteUrl("/") },
			{ "@type": "ListItem", position: 2, name: "Members", item: siteUrl("/members") },
		],
	}}
/>

<PageLayout meta={{ title: "成员", description: "ShareSparks 的作者们。" }}>
	<section class="members" aria-labelledby="members-label">
		<div class="section-label" id="members-label">Members</div>
		<p class="intro">点击头像，了解每位作者。</p>
		<ul class="grid">
			{
				members.map((m) => (
					<li>
						<a data-astro-prefetch href={withBase(`/members/${m.id}/`)}>
							<Avatar name={m.data.name} src={m.data.avatar} size={84} />
							<span class="name">{m.data.name}</span>
							{m.data.bio && <span class="bio">{m.data.bio}</span>}
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<style>
	.members {
		margin-bottom: 88px;
	}
	.intro {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin: 0 0 36px;
		max-width: 60ch;
		text-wrap: pretty;
	}
	.grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
		gap: 20px;
	}
	.grid a {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 10px;
		padding: 24px 14px;
		border: 1px solid var(--hairline);
		border-radius: 12px;
		color: hsl(var(--theme-text));
		transition: border-color 0.2s ease, transform 0.2s ease;
	}
	.grid a:hover {
		border-color: hsl(var(--theme-accent));
		transform: translateY(-2px);
	}
	.name {
		font-family: var(--font-serif);
		font-size: 17px;
		font-weight: 500;
	}
	.bio {
		font-family: var(--font-sans);
		font-size: 13px;
		line-height: 1.5;
		color: hsl(var(--theme-text-muted));
		text-wrap: pretty;
	}

	@media (max-width: 720px) {
		.intro {
			font-size: 17px;
			margin-bottom: 28px;
		}
	}
	@media (max-width: 420px) {
		.members {
			margin-bottom: 56px;
		}
	}
</style>
