---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <div class="meta">
        <FormattedDate date={pubDate} />
        {updatedDate && <span>（更新于 <FormattedDate date={updatedDate} />）</span>}
        {
          tags.length > 0 && (
            <span class="tags">
              {tags.map((t) => (
                <span class="tag">#{t}</span>
              ))}
            </span>
          )
        }
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>

  <p class="back"><a href="/posts">← 返回文章列表</a></p>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
  }
  .post-header h1 {
    margin-bottom: 0.5rem;
  }
  .meta {
    color: var(--muted);
    font-size: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .tag {
    margin-right: 0.4rem;
  }
  .prose :global(h2) {
    margin-top: 2rem;
  }
  .back {
    margin-top: 3rem;
  }
</style>
