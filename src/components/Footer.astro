---
import { SITE } from '@/consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <p>© {year} {SITE.title}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.9rem;
    padding: 1.5rem 0;
  }
  .site-footer p {
    margin: 0;
  }
</style>
